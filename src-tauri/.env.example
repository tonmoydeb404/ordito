# Database Configuration for Development
# Copy this file to .env and modify as needed

# SQLite database URL
# The database file will be created automatically if it doesn't exist
DATABASE_URL=sqlite:./ordito.db

# Note: In production builds, the app will automatically use the system's
# app data directory instead of this .env configuration:
# - Windows: C:\Users\<user>\AppData\Roaming\ordito\ordito.db
# - macOS: ~/Library/Application Support/ordito/ordito.db
# - Linux: ~/.local/share/ordito/ordito.db
