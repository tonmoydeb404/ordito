{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ordito",
  "version": "0.1.0",
  "identifier": "com.ordito.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ordito - Command Management",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Ordito - Command Management"
    }
  },
  "plugins": {
    "notification": {
      "identifier": "com.ordito.app"
    },
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$APPCONFIG/**", "$APPLOCALDATA/**"],
        "deny": []
      }
    },
    "shell": {
      "scope": {
        "allow": [
          {
            "name": "sh",
            "cmd": "sh",
            "args": ["-c", { "validator": "\\S+" }]
          },
          {
            "name": "cmd",
            "cmd": "cmd",
            "args": ["/C", { "validator": "\\S+" }]
          }
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "Copyright © 2025 Ordito Team",
    "longDescription": "Cross-platform desktop application for command execution and management with scheduling capabilities.",
    "shortDescription": "Command management and execution tool"
  }
}
